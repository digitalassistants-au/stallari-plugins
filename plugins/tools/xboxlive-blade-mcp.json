{
  "name": "xboxlive-blade-mcp",
  "description": "Xbox Live operations — profiles, achievements, friends, presence, game library, SmartGlass console control, Store catalog, messaging",
  "version": "0.1.0",
  "author": "Groupthink-dev",
  "licence": "MIT",
  "icon": "/icons/xboxlive-blade-mcp.svg",
  "tier": "community",
  "contract": "gaming-v1",
  "homepage": "https://github.com/Groupthink-dev/xboxlive-blade-mcp",
  "repository": "https://github.com/Groupthink-dev/xboxlive-blade-mcp",
  "install": {
    "runtime": "uv",
    "package": "xboxlive-blade-mcp"
  },
  "env": [
    {
      "name": "XBOX_CLIENT_ID",
      "description": "Azure App client ID"
    },
    {
      "name": "XBOX_CLIENT_SECRET",
      "description": "Azure App client secret (optional for public clients)",
      "secret": true
    },
    {
      "name": "XBOX_TOKEN_PATH",
      "description": "Path to cached OAuth tokens",
      "default": "~/.xboxlive-blade-mcp/tokens.json"
    },
    {
      "name": "XBOX_WRITE_ENABLED",
      "description": "Enable write operations (messaging, friend management, SmartGlass)",
      "default": "false"
    }
  ],
  "setup": {
    "auth_model": "oauth2",
    "complexity": "involved",
    "icon": "gamecontroller.fill",
    "product": "Xbox Live",
    "blurb": "Full Xbox Live access — profiles, achievements, friends, presence, game library, SmartGlass console control, Store catalog, and messaging. 22 tools, 17/17 gaming-v1 contract coverage.",
    "help_text": "Register an Azure app at portal.azure.com with Xbox Live API scope, then run 'xboxlive-blade-mcp auth' for one-time browser login. Tokens auto-refresh after initial setup.",
    "help_links": [
      {
        "label": "Azure App Registration",
        "url": "https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps"
      },
      {
        "label": "Xbox Live API Guide",
        "url": "https://github.com/OpenXbox/xbox-webapi-python#authentication"
      },
      {
        "label": "Setup Instructions",
        "url": "https://github.com/Groupthink-dev/xboxlive-blade-mcp#quick-start"
      }
    ],
    "fields": [
      {
        "key": "XBOX_CLIENT_ID",
        "label": "Azure App Client ID",
        "secret": false,
        "placeholder": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
        "required": true,
        "help": "Application (client) ID from Azure App registrations"
      },
      {
        "key": "XBOX_CLIENT_SECRET",
        "label": "Client Secret",
        "secret": true,
        "placeholder": "Client secret value",
        "required": false,
        "help": "Optional for public client apps"
      },
      {
        "key": "XBOX_WRITE_ENABLED",
        "label": "Enable Write Operations",
        "secret": false,
        "placeholder": "false",
        "required": false,
        "help": "Messaging, friend management, SmartGlass console commands"
      }
    ],
    "test": {
      "endpoint": "https://profile.xboxlive.com/users/me/profile/settings",
      "auth_style": "xbl3"
    },
    "prerequisites": [
      "Microsoft account with Xbox Live",
      "Azure App registration (free)",
      "One-time browser login via 'xboxlive-blade-mcp auth'"
    ],
    "oauth2": {
      "grant_type": "authorization_code",
      "scopes": ["Xboxlive.signin", "Xboxlive.offline_access"],
      "setup_url": "https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps"
    }
  },
  "services": {
    "gaming": {
      "profile": "xbox_profile",
      "achievements": "xbox_achievements",
      "achievement_summary": "xbox_achievement_summary",
      "games_played": "xbox_games",
      "games_recent": "xbox_games_recent",
      "friends": "xbox_friends",
      "presence": "xbox_presence",
      "search_users": "xbox_search_users",
      "achievement_compare": "xbox_achievement_compare",
      "achievement_groups": "xbox_achievement_groups",
      "games_purchased": "xbox_games_purchased",
      "devices": "xbox_consoles",
      "game_details": "xbox_game_details",
      "search_games": "xbox_search_games",
      "send_message": "xbox_send_message",
      "friend_add": "xbox_friend_add",
      "friend_remove": "xbox_friend_remove"
    }
  },
  "conformance": {
    "required": "4/4",
    "recommended": "4/4",
    "optional": "6/6",
    "gated": "3/3",
    "last_tested": null
  },
  "notes": "Full-featured Xbox Live MCP built on xbox-webapi-python (200+ stars). 22 tools across 8 domains. The only MCP with SmartGlass console control, Xbox messaging, game clips, and Store catalog. Write gates on mutations, confirm gates on SmartGlass power commands and friend removal. Token-efficient pipe-delimited output."
}

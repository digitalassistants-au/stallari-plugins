{
  "name": "betfair-blade-mcp",
  "version": "0.1.0",
  "description": "Betfair Exchange MCP Server — markets, prices, orders, account, certificate auth, weight-aware rate limiting",
  "author": "groupthink-dev",
  "licence": "MIT",
  "icon": "/icons/betfair-blade-mcp.svg",
  "tier": "certified",
  "contract": "betting-exchange-v1",
  "homepage": "https://github.com/groupthink-dev/betfair-blade-mcp",
  "repository": "https://github.com/groupthink-dev/betfair-blade-mcp",
  "install": {
    "runtime": "uv",
    "package": "betfair-blade-mcp",
    "command": "betfair-blade-mcp"
  },
  "env": [
    {
      "name": "BETFAIR_APP_KEY",
      "description": "Betfair API application key",
      "secret": true
    },
    {
      "name": "BETFAIR_USERNAME",
      "description": "Betfair account username"
    },
    {
      "name": "BETFAIR_PASSWORD",
      "description": "Betfair account password",
      "secret": true
    },
    {
      "name": "BETFAIR_CERT_PATH",
      "description": "Path to client certificate (.pem)"
    },
    {
      "name": "BETFAIR_KEY_PATH",
      "description": "Path to client private key (.pem)"
    },
    {
      "name": "BETFAIR_EXCHANGE",
      "description": "Exchange endpoint: uk (default) or au",
      "default": "uk"
    },
    {
      "name": "BETFAIR_WRITE_ENABLED",
      "description": "Enable write operations (place/cancel/update/replace orders, heartbeat)",
      "default": "false"
    }
  ],
  "setup": {
    "auth_model": "certificate",
    "complexity": "involved",
    "icon": "chart.line.uptrend.xyaxis",
    "product": "Betfair Exchange",
    "blurb": "Full Betfair Exchange access — markets, prices, orders, account. Certificate auth with weight-aware rate limiting. 22 tools, full betting-exchange-v1 contract.",
    "help_text": "Register a Betfair API application at developer.betfair.com. Generate a self-signed certificate and link it to your account. Certificate auth avoids interactive login.",
    "help_links": [
      {
        "label": "Betfair API Getting Started",
        "url": "https://developer.betfair.com/en/get-started/"
      },
      {
        "label": "Certificate Login Guide",
        "url": "https://docs.developer.betfair.com/display/1smk3cen4v3lu3yomq5qye0ni/Non-Interactive+(bot)+login"
      },
      {
        "label": "API Reference",
        "url": "https://docs.developer.betfair.com/display/1smk3cen4v3lu3yomq5qye0ni/Betting+API"
      }
    ],
    "fields": [
      {
        "key": "BETFAIR_APP_KEY",
        "label": "Application Key",
        "secret": true,
        "required": true,
        "placeholder": "Your Betfair app key",
        "help": "From developer.betfair.com > My Apps"
      },
      {
        "key": "BETFAIR_USERNAME",
        "label": "Username",
        "secret": false,
        "required": true,
        "placeholder": "Betfair account username"
      },
      {
        "key": "BETFAIR_PASSWORD",
        "label": "Password",
        "secret": true,
        "required": true,
        "placeholder": "Betfair account password"
      },
      {
        "key": "BETFAIR_CERT_PATH",
        "label": "Certificate Path",
        "secret": false,
        "required": true,
        "placeholder": "~/.betfair/client-2048.pem",
        "help": "Self-signed client certificate linked to your Betfair account"
      },
      {
        "key": "BETFAIR_KEY_PATH",
        "label": "Private Key Path",
        "secret": false,
        "required": true,
        "placeholder": "~/.betfair/client-2048.key",
        "help": "Private key corresponding to the client certificate"
      },
      {
        "key": "BETFAIR_EXCHANGE",
        "label": "Exchange",
        "secret": false,
        "required": false,
        "placeholder": "uk",
        "help": "uk (default) or au for Australian exchange"
      },
      {
        "key": "BETFAIR_WRITE_ENABLED",
        "label": "Enable Trading",
        "secret": false,
        "required": false,
        "placeholder": "false",
        "help": "Place, cancel, update, and replace orders. Real money operations."
      }
    ],
    "test": {
      "endpoint": "https://identitysso-cert.betfair.com/api/certlogin",
      "auth_style": "certificate"
    },
    "prerequisites": [
      "Betfair account with API access enabled",
      "Betfair API application key (from developer.betfair.com)",
      "Self-signed client certificate linked to account"
    ]
  },
  "services": {
    "betting-exchange": {
      "event_types": "betfair_event_types",
      "events": "betfair_events",
      "market_catalogue": "betfair_market_catalogue",
      "market_book": "betfair_market_book",
      "account_funds": "betfair_account_funds",
      "current_orders": "betfair_current_orders",
      "login_status": "betfair_login_status",
      "keepalive": "betfair_keepalive",
      "competitions": "betfair_competitions",
      "runner_book": "betfair_runner_book",
      "navigation": "betfair_navigation",
      "account_details": "betfair_account_details",
      "account_statement": "betfair_account_statement",
      "cleared_orders": "betfair_cleared_orders",
      "market_pnl": "betfair_market_pnl",
      "venues": "betfair_venues",
      "currency_rates": "betfair_currency_rates",
      "place_orders": "betfair_place_orders",
      "cancel_orders": "betfair_cancel_orders",
      "update_orders": "betfair_update_orders",
      "replace_orders": "betfair_replace_orders",
      "heartbeat": "betfair_heartbeat"
    }
  },
  "certification": {
    "status": "certified",
    "validated_version": "0.1.0",
    "platform_tested": ["darwin-arm64", "linux-x86_64"],
    "security_notes": "Certificate auth (no interactive login). Write gates on all order operations. Confirm gates on place_orders. Weight-aware rate limiting (per-endpoint). Real money at stake when write-enabled."
  },
  "conformance": {
    "required": "8/8",
    "recommended": "7/7",
    "optional": "2/2",
    "gated": "5/5",
    "last_tested": "2026-04-07"
  }
}

{
  "name": "caldav-blade-mcp",
  "title": "CalDAV Calendar",
  "description": "CalDAV calendar operations — protocol-level access to any CalDAV server",
  "version": "0.1.0",
  "author": "groupthink-dev",
  "licence": "MIT",
  "icon": "/icons/caldav-blade-mcp.svg",
  "tier": "certified",
  "contract": "calendar-v1",
  "repository": "https://github.com/groupthink-dev/caldav-blade-mcp",
  "install": {
    "runtime": "uv",
    "package": "caldav-blade-mcp"
  },
  "env": [
    {
      "name": "CALDAV_URL",
      "description": "CalDAV server URL"
    },
    {
      "name": "CALDAV_USERNAME",
      "description": "CalDAV account username"
    },
    {
      "name": "CALDAV_PASSWORD",
      "description": "CalDAV account password or app-specific password",
      "secret": true
    }
  ],
  "setup": {
    "auth_model": "basic",
    "complexity": "moderate",
    "icon": "calendar",
    "product": "CalDAV Account",
    "help_text": "Provide your CalDAV server URL, username, and password. For iCloud: use appleid.apple.com → Sign-In and Security → App-Specific Passwords. For Fastmail: use an API token as the password. For Google Calendar: use a Google app password.",
    "help_links": [
      {
        "label": "iCloud App-Specific Passwords",
        "url": "https://support.apple.com/en-us/102654"
      },
      {
        "label": "Fastmail CalDAV Setup",
        "url": "https://www.fastmail.help/hc/en-us/articles/1500000278342-Server-names-and-ports"
      }
    ],
    "fields": [
      {
        "key": "CALDAV_URL",
        "label": "Server URL",
        "secret": false,
        "placeholder": "https://caldav.icloud.com"
      },
      {
        "key": "CALDAV_USERNAME",
        "label": "Username",
        "secret": false,
        "placeholder": "user@example.com"
      },
      {
        "key": "CALDAV_PASSWORD",
        "label": "Password",
        "secret": true,
        "placeholder": "App-specific password"
      }
    ],
    "test": {
      "endpoint": "{CALDAV_URL}",
      "auth_style": "basic"
    }
  },
  "conformance": {
    "required": "4/4",
    "recommended": "3/3",
    "optional": "1/1",
    "last_tested": "2026-03-25"
  }
}

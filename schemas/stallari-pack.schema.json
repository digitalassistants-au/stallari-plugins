{
  "$defs": {
    "agent": {
      "additionalProperties": true,
      "properties": {
        "model_preference": {
          "description": "Preferred model/provider keys in priority order.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "prompt": {
          "description": "System prompt for the agent.",
          "type": "string"
        },
        "role": {
          "description": "Agent role (e.g. operator, specialist, reviewer).",
          "type": "string"
        }
      },
      "required": [
        "role"
      ],
      "type": "object"
    },
    "requirements": {
      "additionalProperties": false,
      "properties": {
        "capabilities": {
          "description": "Reserved for future capability requirements.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "services": {
          "items": {
            "$ref": "#/$defs/serviceRequirement"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "serviceRequirement": {
      "additionalProperties": false,
      "properties": {
        "operations": {
          "description": "Specific operations required from this service.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "service": {
          "description": "Abstract service name (e.g. email, tasks, calendar, vault).",
          "type": "string"
        }
      },
      "required": [
        "service"
      ],
      "type": "object"
    },
    "skill": {
      "additionalProperties": true,
      "properties": {
        "agent": {
          "description": "Agent name that executes this skill (key in agents dict).",
          "type": "string"
        },
        "category": {
          "description": "Skill category — what role this skill plays in the workflow (v1.2).",
          "enum": [
            "ingest",
            "triage",
            "digest",
            "transform",
            "notify",
            "review",
            "sync",
            "report"
          ],
          "type": "string"
        },
        "depends_on": {
          "description": "Skills that must complete before this one.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "description": {
          "description": "One-line human-readable description.",
          "type": "string"
        },
        "graph": {
          "default": "react-extract",
          "description": "Execution graph topology (v1.6, DD119/DD123/DD126). react-extract = ReAct + JSON extraction (default). react = lightweight, no extraction. react-verify = ReAct + deterministic verification + refinement. cascade = classify → react → escalate (tiered cost).",
          "enum": [
            "react-extract",
            "react",
            "react-verify",
            "cascade"
          ],
          "type": "string"
        },
        "graph_config": {
          "additionalProperties": false,
          "description": "Graph-specific configuration (v1.6, DD126). Used with cascade graphs for multi-tier model routing.",
          "properties": {
            "classify_model": {
              "description": "Model identifier for the classify tier (e.g. claude-haiku-4-5-20251001).",
              "type": "string"
            },
            "confidence_threshold": {
              "default": 0.85,
              "description": "ClassifyNode confidence cutoff. Items at or above threshold short-circuit to extraction.",
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            "escalation_model": {
              "description": "Model identifier for escalation when the react tier exhausts its budget.",
              "type": "string"
            }
          },
          "type": "object"
        },
        "inputs": {
          "description": "Skill-level user inputs, same shape as config.user_inputs (v1.2).",
          "items": {
            "$ref": "#/$defs/userInput"
          },
          "type": "array"
        },
        "name": {
          "description": "Skill identifier (kebab-case).",
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "outputs": {
          "description": "What this skill produces (v1.2).",
          "items": {
            "additionalProperties": false,
            "properties": {
              "description": {
                "description": "What this output contains.",
                "type": "string"
              },
              "type": {
                "description": "Output type (e.g. vault_note, task, notification, report).",
                "type": "string"
              }
            },
            "required": [
              "type"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "prompt": {
          "description": "Detailed LLM prompt. Can reference {{service.operation}} syntax.",
          "type": "string"
        },
        "services_used": {
          "description": "Services and operations this skill actually calls (v1.2).",
          "items": {
            "additionalProperties": false,
            "properties": {
              "operations": {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              "service": {
                "type": "string"
              }
            },
            "required": [
              "service"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "trigger": {
          "$ref": "#/$defs/trigger"
        },
        "webhook_name": {
          "description": "Name of the webhook that triggers this skill (v1.4, DD113). Links to a webhooks[] entry name or a HooksConfig webhook name.",
          "type": "string"
        }
      },
      "required": [
        "name",
        "prompt"
      ],
      "type": "object"
    },
    "trigger": {
      "additionalProperties": false,
      "properties": {
        "on_demand": {
          "description": "Manual trigger only.",
          "type": "boolean"
        },
        "schedule": {
          "description": "Cron expression (5-field, e.g. \"0 7 * * *\").",
          "type": "string"
        },
        "watch": {
          "description": "Paths to watch for changes.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "webhook": {
          "$ref": "#/$defs/webhookTrigger",
          "description": "Webhook-triggered execution (v1.4, DD113)."
        }
      },
      "type": "object"
    },
    "userInput": {
      "additionalProperties": false,
      "properties": {
        "choices": {
          "description": "Valid options (for type=choice).",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "default": {
          "description": "Default value (any JSON type)."
        },
        "description": {
          "description": "Longer explanation.",
          "type": "string"
        },
        "key": {
          "description": "Configuration key (snake_case).",
          "pattern": "^[a-z][a-z0-9_]*$",
          "type": "string"
        },
        "label": {
          "description": "Human-readable label.",
          "type": "string"
        },
        "required": {
          "default": false,
          "description": "Whether input is mandatory.",
          "type": "boolean"
        },
        "type": {
          "description": "Input type (e.g. string, number, boolean, choice, time).",
          "type": "string"
        }
      },
      "required": [
        "key",
        "type",
        "label"
      ],
      "type": "object"
    },
    "webhookTrigger": {
      "additionalProperties": false,
      "properties": {
        "auth": {
          "default": "hmac",
          "description": "Verification method for inbound webhook requests.",
          "enum": [
            "hmac",
            "bearer",
            "none"
          ],
          "type": "string"
        },
        "path": {
          "description": "URL path suffix for the webhook endpoint (e.g. /hooks/tech-support).",
          "pattern": "^/hooks/",
          "type": "string"
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "workflow": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "description": "Workflow identifier.",
          "type": "string"
        },
        "schedule": {
          "description": "Optional cron expression for the entire workflow.",
          "type": "string"
        },
        "steps": {
          "items": {
            "$ref": "#/$defs/workflowStep"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "name",
        "steps"
      ],
      "type": "object"
    },
    "workflowStep": {
      "additionalProperties": false,
      "properties": {
        "after": {
          "description": "Skills that must complete before this step.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "condition": {
          "description": "Execution condition (e.g. \"always\").",
          "type": "string"
        },
        "skill": {
          "description": "Skill name to execute (must exist in skills array).",
          "type": "string"
        }
      },
      "required": [
        "skill"
      ],
      "type": "object"
    }
  },
  "$id": "https://stallari.app/schemas/stallari-pack.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "Schema for pack manifests (stallari-plugin.yaml with pack: field). Public Pack Spec v1.0/v1.1/v1.2/v1.3/v1.4/v1.5/v1.6 (DD92, DD99, DD104, DD113, DD119, DD126).",
  "properties": {
    "access": {
      "default": "public",
      "description": "Access control. Public = visible to everyone. Private = org-scoped, visible only to authenticated org members (v1.3, DD104).",
      "enum": [
        "public",
        "private"
      ],
      "type": "string"
    },
    "agents": {
      "additionalProperties": {
        "$ref": "#/$defs/agent"
      },
      "description": "Named agent definitions (dict of name → agent config).",
      "type": "object"
    },
    "author": {
      "additionalProperties": true,
      "properties": {
        "name": {
          "description": "Author name.",
          "type": "string"
        },
        "url": {
          "description": "Author profile or website URL.",
          "format": "uri",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "author_type": {
      "description": "Author provenance. first-party = published and maintained by Stallari.",
      "enum": [
        "first-party",
        "community"
      ],
      "type": "string"
    },
    "config": {
      "additionalProperties": false,
      "properties": {
        "user_inputs": {
          "description": "User-configurable parameters.",
          "items": {
            "$ref": "#/$defs/userInput"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "data": {
      "additionalProperties": false,
      "description": "Mandatory data access policy. Enforced by sandbox at runtime.",
      "properties": {
        "phones_home": {
          "description": "Whether pack calls external APIs beyond declared services.",
          "type": "boolean"
        },
        "reads": {
          "description": "Services this pack reads from.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "stores": {
          "description": "Persistence model.",
          "enum": [
            "nothing",
            "local",
            "remote"
          ],
          "type": "string"
        },
        "writes": {
          "description": "Services this pack writes to.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "reads",
        "writes",
        "stores",
        "phones_home"
      ],
      "type": "object"
    },
    "description": {
      "description": "One-line summary of what this pack does.",
      "maxLength": 300,
      "type": "string"
    },
    "encryption": {
      "additionalProperties": false,
      "description": "Encryption configuration for sealed packs (v1.2).",
      "properties": {
        "key_delivery": {
          "description": "Key delivery mechanism (e.g. paddle, registry-escrow, direct).",
          "type": "string"
        },
        "method": {
          "description": "Encryption method for sealed pack prompts (e.g. aes-256-gcm).",
          "type": "string"
        }
      },
      "required": [
        "method",
        "key_delivery"
      ],
      "type": "object"
    },
    "forked_from": {
      "additionalProperties": false,
      "description": "Fork provenance — which pack and version this was forked from (v1.2).",
      "properties": {
        "name": {
          "description": "Name of the original pack.",
          "type": "string"
        },
        "version": {
          "description": "Version of the original pack that was forked.",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "type": "object"
    },
    "icon": {
      "description": "Relative URL path to icon asset for marketplace display (e.g. '/icons/stallari-core.svg').",
      "type": "string"
    },
    "licence": {
      "description": "SPDX licence identifier (e.g. MIT, Apache-2.0).",
      "type": "string"
    },
    "min_stallari": {
      "description": "Minimum Stallari version (e.g. \"0.29\"). Major.minor only.",
      "pattern": "^\\d+\\.\\d+$",
      "type": "string"
    },
    "name": {
      "description": "Pack name (title-case, human-readable).",
      "type": "string"
    },
    "organization": {
      "description": "Owning organisation slug. Required when access is private (v1.3, DD104).",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "type": "string"
    },
    "pack": {
      "description": "Pack spec version.",
      "enum": [
        "1.0",
        "1.1",
        "1.2",
        "1.3",
        "1.4",
        "1.5",
        "1.6"
      ],
      "type": "string"
    },
    "pricing": {
      "default": null,
      "description": "Pricing configuration (v1.1). Null = free.",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "additionalProperties": false,
          "properties": {
            "amount": {
              "description": "Price amount (USD).",
              "minimum": 0,
              "type": "number"
            },
            "interval": {
              "description": "Billing interval (subscription only).",
              "enum": [
                "month",
                "year"
              ],
              "type": "string"
            },
            "model": {
              "description": "Revenue model.",
              "enum": [
                "free",
                "tip",
                "one-time",
                "subscription"
              ],
              "type": "string"
            },
            "paddle_product_id": {
              "description": "Paddle product ID for checkout.",
              "type": "string"
            },
            "tip": {
              "description": "Whether tips are accepted.",
              "type": "boolean"
            }
          },
          "type": "object"
        }
      ]
    },
    "readiness": {
      "description": "Testing completeness. production = all certification checklist items pass. beta = partially tested. experimental = untested. stub = scaffolded but not functional.",
      "enum": [
        "production",
        "beta",
        "experimental",
        "stub"
      ],
      "type": "string"
    },
    "readme": {
      "description": "Inline README content (v1.2). Mandatory when visibility is sealed (enforced by validator, not schema).",
      "type": "string"
    },
    "recommends": {
      "$ref": "#/$defs/requirements",
      "description": "Soft requirements — missing services degrade gracefully."
    },
    "requires": {
      "$ref": "#/$defs/requirements",
      "description": "Hard requirements — missing services prevent pack execution."
    },
    "skills": {
      "description": "Ordered skill list. At least one required.",
      "items": {
        "$ref": "#/$defs/skill"
      },
      "minItems": 1,
      "type": "array"
    },
    "tier": {
      "default": "community",
      "deprecated": true,
      "description": "DEPRECATED — use author_type + readiness. Legacy trust tier. Certified = first-party or audited. Verified = reviewed. Community = unreviewed. Either tier or both author_type + readiness should be present.",
      "enum": [
        "certified",
        "verified",
        "community"
      ],
      "type": "string"
    },
    "version": {
      "description": "Pack semantic version (major.minor.patch).",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "type": "string"
    },
    "visibility": {
      "default": "open",
      "description": "Visibility mode. Open = public and forkable. Sealed = prompts encrypted at rest.",
      "enum": [
        "open",
        "sealed"
      ],
      "type": "string"
    },
    "workflows": {
      "description": "Multi-skill execution sequences (DAGs).",
      "items": {
        "$ref": "#/$defs/workflow"
      },
      "type": "array"
    }
  },
  "required": [
    "pack",
    "name",
    "description",
    "data",
    "skills"
  ],
  "title": "Stallari Pack Manifest",
  "type": "object"
}

{
  "$id": "https://stallari.app/schemas/contracts/billing-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Billing service contract v1 — 28 operations across products, subscriptions, transactions, and payments.",
  "operations": [
    {
      "classification": "required",
      "description": "List products with status and category filters",
      "name": "products"
    },
    {
      "classification": "required",
      "description": "Get product detail with optional price inclusion",
      "name": "product"
    },
    {
      "classification": "required",
      "description": "List prices with product and status filters",
      "name": "prices"
    },
    {
      "classification": "required",
      "description": "List or search customers",
      "name": "customers"
    },
    {
      "classification": "required",
      "description": "List subscriptions with status and customer filters",
      "name": "subscriptions"
    },
    {
      "classification": "required",
      "description": "List transactions with date range and status filters",
      "name": "transactions"
    },
    {
      "classification": "recommended",
      "description": "Get customer detail",
      "name": "customer"
    },
    {
      "classification": "recommended",
      "description": "Get subscription detail with billing period and items",
      "name": "subscription"
    },
    {
      "classification": "recommended",
      "description": "Get transaction detail with totals and line items",
      "name": "transaction"
    },
    {
      "classification": "recommended",
      "description": "Get invoice PDF download URL",
      "name": "invoice"
    },
    {
      "classification": "recommended",
      "description": "List adjustments (refunds, credits, chargebacks)",
      "name": "adjustments"
    },
    {
      "classification": "recommended",
      "description": "List and get discounts",
      "name": "discounts"
    },
    {
      "classification": "recommended",
      "description": "List billing events",
      "name": "events"
    },
    {
      "classification": "recommended",
      "description": "Get customer credit balance",
      "name": "credit_balance"
    },
    {
      "classification": "optional",
      "description": "List and inspect webhook notifications",
      "name": "notifications"
    },
    {
      "classification": "optional",
      "description": "List and create billing reports",
      "name": "reports"
    },
    {
      "classification": "optional",
      "description": "List customer payment methods",
      "name": "payment_methods"
    },
    {
      "classification": "optional",
      "description": "Preview transaction pricing without persistence",
      "name": "preview_transaction"
    },
    {
      "classification": "optional",
      "description": "HMAC-SHA256 webhook signature verification",
      "name": "verify_webhook"
    },
    {
      "classification": "optional",
      "description": "Paddle IP addresses for webhook firewall allowlisting",
      "name": "ip_addresses"
    },
    {
      "classification": "gated",
      "description": "Create a new customer",
      "name": "create_customer"
    },
    {
      "classification": "gated",
      "description": "Update subscription items and proration",
      "name": "update_subscription"
    },
    {
      "classification": "gated",
      "description": "Cancel a subscription (destructive, requires confirmation)",
      "name": "cancel_subscription"
    },
    {
      "classification": "gated",
      "description": "Create a new transaction",
      "name": "create_transaction"
    },
    {
      "classification": "gated",
      "description": "Create a refund, credit, or chargeback",
      "name": "create_adjustment"
    },
    {
      "classification": "gated",
      "description": "Create a discount code or percentage",
      "name": "create_discount"
    },
    {
      "classification": "gated",
      "description": "Replay a failed webhook notification",
      "name": "replay_notification"
    },
    {
      "classification": "gated",
      "description": "Create and run billing simulations",
      "name": "simulate"
    }
  ],
  "properties": {
    "name": {
      "const": "billing-v1"
    },
    "service": {
      "const": "billing"
    },
    "version": {
      "const": 1
    }
  },
  "title": "billing-v1",
  "type": "object"
}

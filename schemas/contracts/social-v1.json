{
  "$id": "https://stallari.app/schemas/contracts/social-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Social platform contract v1 — 20 operations across timelines, statuses, accounts, and interactions.",
  "operations": [
    {
      "classification": "required",
      "description": "Read timeline (home, public, local, hashtag, list)",
      "name": "timeline"
    },
    {
      "classification": "required",
      "description": "Get a specific status/post by ID",
      "name": "status"
    },
    {
      "classification": "required",
      "description": "Search statuses, accounts, and hashtags",
      "name": "search"
    },
    {
      "classification": "required",
      "description": "List notifications (mentions, favourites, boosts, follows)",
      "name": "notifications"
    },
    {
      "classification": "recommended",
      "description": "Get thread context (ancestors and descendants) for a status",
      "name": "context"
    },
    {
      "classification": "recommended",
      "description": "Get account profile and statuses",
      "name": "account"
    },
    {
      "classification": "recommended",
      "description": "Get trending hashtags, statuses, and links",
      "name": "trending"
    },
    {
      "classification": "recommended",
      "description": "List bookmarked statuses",
      "name": "bookmarks"
    },
    {
      "classification": "recommended",
      "description": "List favourited statuses",
      "name": "favourites"
    },
    {
      "classification": "recommended",
      "description": "Check follow/block/mute relationships with accounts",
      "name": "relationships"
    },
    {
      "classification": "optional",
      "description": "Manage curated lists of accounts",
      "name": "lists"
    },
    {
      "classification": "optional",
      "description": "Manage content filters and keyword blocks",
      "name": "filters"
    },
    {
      "classification": "optional",
      "description": "List direct message conversations",
      "name": "conversations"
    },
    {
      "classification": "optional",
      "description": "Get instance information, rules, and configuration",
      "name": "instance"
    },
    {
      "classification": "gated",
      "description": "Create a new status (text, media, poll, scheduled)",
      "name": "post"
    },
    {
      "classification": "gated",
      "description": "Delete a status",
      "name": "delete"
    },
    {
      "classification": "gated",
      "description": "Favourite or unfavourite a status",
      "name": "favourite"
    },
    {
      "classification": "gated",
      "description": "Boost (reblog) or unboost a status",
      "name": "boost"
    },
    {
      "classification": "gated",
      "description": "Follow or unfollow an account",
      "name": "follow"
    },
    {
      "classification": "gated",
      "description": "Block, unblock, mute, or unmute an account",
      "name": "block"
    }
  ],
  "properties": {
    "name": {
      "const": "social-v1"
    },
    "service": {
      "const": "social"
    },
    "version": {
      "const": 1
    }
  },
  "title": "social-v1",
  "type": "object"
}
